{
  "name": "gta-free-stem-opportunities",
  "version": "0.1.0",
  "description": "Open-source free STEM opportunity finder for GTA families, students, educators, and community hosts.",
  "private": true,
  "homepage": "https://gta-free-stem.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/rupayon123/gta-free-stem-opportunities.git"
  },
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "tsx scripts/export-public-opportunities.ts && next build && cp hosting/static-vercel.json out/vercel.json",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "ingest:dry-run": "tsx scripts/ingest-dry-run.ts",
    "discover": "tsx scripts/discover-opportunities.ts",
    "discover:summary": "tsx scripts/discover-opportunities.ts --summary",
    "discover:write": "tsx scripts/discover-opportunities.ts --summary --write-review",
    "discover:sql": "tsx scripts/discover-opportunities.ts --format=sql",
    "generate:library": "tsx scripts/generate-library-opportunities.ts",
    "export:public-feed": "tsx scripts/export-public-opportunities.ts",
    "engine:refresh": "npm run generate:library && npm run discover:write && npm run export:public-feed && npm run qa",
    "supabase:check": "tsx scripts/check-supabase.ts",
    "supabase:seed": "tsx scripts/export-supabase-seed.ts",
    "qa": "tsx scripts/qa-check.ts",
    "deploy:pages": "npm run build && npx --yes wrangler pages deploy out --project-name=gta-free-stem"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "lucide-react": "^1.16.0",
    "maplibre-gl": "^5.24.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "postcss": "^8.5.10"
  }
}
